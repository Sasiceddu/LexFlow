generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

enum ConfigurableFieldScope {
  GENERAL
  PHASE
}

enum ConfigurableFieldType {
  SHORT_TEXT
  LONG_TEXT
  NUMBER
  AMOUNT
  DATE
  DROPDOWN
  BOOLEAN
  NOTE
  FILE
}

enum PracticeDocumentType {
  DECREE
  INVOICE
  PEC
  ATTACHMENT
  OTHER
}

model AppSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemEvent {
  id        String   @id @default(uuid())
  type      String
  message   String?
  metadata  String?
  createdAt DateTime @default(now())
}

model Collaborator {
  id          String     @id @default(uuid())
  firstName   String
  lastName    String
  displayName String
  notes       String?
  isActive    Boolean    @default(true)
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  practices   Practice[]

  @@index([deletedAt])
  @@index([isActive])
}

model Professional {
  id          String     @id @default(uuid())
  firstName   String
  lastName    String
  displayName String
  email       String?
  phone       String?
  notes       String?
  isActive    Boolean    @default(true)
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  practices   Practice[]

  @@index([deletedAt])
  @@index([isActive])
}

model Workflow {
  id          String               @id @default(uuid())
  name        String               @unique
  description String?
  isDefault   Boolean              @default(false)
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  phases      WorkflowPhase[]
  transitions WorkflowTransition[]
  practices   Practice[]

  @@index([isActive])
  @@index([isDefault])
}

model WorkflowPhase {
  id                     String               @id @default(uuid())
  workflowId             String
  name                   String
  technicalKey           String
  category               String
  description            String?
  order                  Int
  color                  String?
  isInitial              Boolean              @default(false)
  isFinal                Boolean              @default(false)
  isActive               Boolean              @default(true)
  deletedAt              DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  workflow               Workflow             @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  configurableFields     ConfigurableField[]
  currentPractices       Practice[]           @relation("PracticeCurrentPhase")
  documents              PracticeDocument[]
  pecRecipients          PecRecipient[]
  historiesFromPhase     PracticeHistory[]    @relation("PracticeHistoryFromPhase")
  historiesToPhase       PracticeHistory[]    @relation("PracticeHistoryToPhase")
  transitionsFromPhase   WorkflowTransition[] @relation("WorkflowTransitionFromPhase")
  transitionsToPhase     WorkflowTransition[] @relation("WorkflowTransitionToPhase")

  @@unique([workflowId, technicalKey])
  @@index([workflowId, order])
  @@index([deletedAt])
  @@index([isActive])
}

model WorkflowTransition {
  id           String        @id @default(uuid())
  workflowId   String
  fromPhaseId  String
  toPhaseId    String
  actionLabel  String
  technicalKey String
  order        Int
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  workflow     Workflow      @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  fromPhase    WorkflowPhase @relation("WorkflowTransitionFromPhase", fields: [fromPhaseId], references: [id], onDelete: Restrict)
  toPhase      WorkflowPhase @relation("WorkflowTransitionToPhase", fields: [toPhaseId], references: [id], onDelete: Restrict)

  @@unique([workflowId, technicalKey])
  @@index([workflowId, order])
  @@index([fromPhaseId])
  @@index([toPhaseId])
  @@index([isActive])
}

model ConfigurableField {
  id              String                 @id @default(uuid())
  scope           ConfigurableFieldScope
  sectionKey      String
  phaseId         String?
  label           String
  technicalKey    String
  fieldType       ConfigurableFieldType
  isRequired      Boolean                @default(false)
  showInTable     Boolean                @default(false)
  useInFilters    Boolean                @default(false)
  includeInExport Boolean                @default(false)
  order           Int
  dropdownMenuId  String?
  isActive        Boolean                @default(true)
  deletedAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  phase           WorkflowPhase?         @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  dropdownMenu    DropdownMenu?          @relation(fields: [dropdownMenuId], references: [id], onDelete: SetNull)

  @@index([scope])
  @@index([phaseId])
  @@index([dropdownMenuId])
  @@index([sectionKey, order])
  @@index([deletedAt])
  @@index([isActive])
}

model DropdownMenu {
  id             String              @id @default(uuid())
  name           String
  technicalKey   String              @unique
  scope          String?
  isSystem       Boolean             @default(false)
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  options        DropdownOption[]
  fields         ConfigurableField[]

  @@index([isActive])
  @@index([isSystem])
}

model DropdownOption {
  id               String       @id @default(uuid())
  menuId           String
  label            String
  value            String
  order            Int
  triggersPecBlock Boolean      @default(false)
  isActive         Boolean      @default(true)
  deletedAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  menu             DropdownMenu @relation(fields: [menuId], references: [id], onDelete: Restrict)

  @@unique([menuId, value])
  @@index([menuId, order])
  @@index([deletedAt])
  @@index([isActive])
}

model Practice {
  id                String             @id @default(uuid())
  code              String             @unique
  name              String
  collaboratorId    String?
  professionalId    String?
  workflowId        String
  currentPhaseId    String
  activityType      String?
  hearingDate       DateTime?
  depositDate       DateTime?
  office            String?
  judicialAuthority String?
  requestedAmount   Decimal?
  grantedAmount     Decimal?
  invoicedAmount    Decimal?
  liquidatedAmount  Decimal?
  notes             String?
  customData        Json?
  deletedAt         DateTime?
  deletedBy         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  collaborator      Collaborator?      @relation(fields: [collaboratorId], references: [id], onDelete: SetNull)
  professional      Professional?      @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  workflow          Workflow           @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  currentPhase      WorkflowPhase      @relation("PracticeCurrentPhase", fields: [currentPhaseId], references: [id], onDelete: Restrict)
  documents         PracticeDocument[]
  histories         PracticeHistory[]
  pecRecipients     PecRecipient[]

  @@index([collaboratorId])
  @@index([professionalId])
  @@index([workflowId])
  @@index([currentPhaseId])
  @@index([deletedAt])
  @@index([depositDate])
  @@index([hearingDate])
}

model PracticeHistory {
  id          String         @id @default(uuid())
  practiceId  String
  eventType   String
  title       String
  description String?
  fromPhaseId String?
  toPhaseId   String?
  data        Json?
  createdAt   DateTime       @default(now())
  practice    Practice       @relation(fields: [practiceId], references: [id], onDelete: Restrict)
  fromPhase   WorkflowPhase? @relation("PracticeHistoryFromPhase", fields: [fromPhaseId], references: [id], onDelete: SetNull)
  toPhase     WorkflowPhase? @relation("PracticeHistoryToPhase", fields: [toPhaseId], references: [id], onDelete: SetNull)

  @@index([practiceId])
  @@index([eventType])
  @@index([createdAt])
  @@index([fromPhaseId])
  @@index([toPhaseId])
}

model PracticeDocument {
  id           String               @id @default(uuid())
  practiceId   String
  phaseId      String?
  documentType PracticeDocumentType
  fileName     String
  originalName String
  mimeType     String?
  size         Int?
  storagePath  String
  uploadedAt   DateTime             @default(now())
  deletedAt    DateTime?
  practice     Practice             @relation(fields: [practiceId], references: [id], onDelete: Restrict)
  phase        WorkflowPhase?       @relation(fields: [phaseId], references: [id], onDelete: SetNull)

  @@index([practiceId])
  @@index([phaseId])
  @@index([documentType])
  @@index([deletedAt])
}

model PecRecipient {
  id          String         @id @default(uuid())
  practiceId  String
  phaseId     String?
  contextKey  String
  email       String
  description String?
  sentAt      DateTime?
  subject     String?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  practice    Practice       @relation(fields: [practiceId], references: [id], onDelete: Restrict)
  phase       WorkflowPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)

  @@index([practiceId])
  @@index([phaseId])
  @@index([contextKey])
  @@index([sentAt])
}
